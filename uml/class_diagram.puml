	class Item {
		<<abstract>>
		-itemName : String
		-itemQuantity : Int
		-perishable : Boolean
		+getQuantity()
		+setQuantity()
		+useTarget()
		+itemEffect()
	}
	class Potion {
		-itemName : String
		-itemQuantity : Int
		-perishable : Boolean
		+getQuantity()
		+setQuantity()
