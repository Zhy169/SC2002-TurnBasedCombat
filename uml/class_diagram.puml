classDiagram
direction TB
    class Difficulty {
	    -combatWaves : Entity_Wave[]
		-currentWave : Int
	    +getAllWaves()
		+getNextWave()
	    +addCombatWave()
		+removeCombatWave()
    }

    class Easy {
	    -combatWaves : Entity_Wave[]
		-currentWave : Int
    }

    class Medium {
	    -combatWaves : Entity_Wave[]
		-currentWave : Int
    }

    class Hard {
	    -combatWaves : Entity_Wave[]
		-currentWave : Int
    }

    class Entities {
	    -playerControl : Boolean
	    -ongoingSpecialStatus : specialStatus[]
	    +action()
    }

    class Player_Class {
	    -playerControl : Boolean
	    -bag : Item_Bag
	    -startingNumOfItems : Int
	    -specialSkillName : String
		-specialSkillCD : Int
	    +useItem()
	    +gainItem()
	    +loseItem()
	    +defend()
	    +specialSkill(Enemy_type)
		+getSpecialSkillCD()
		+getSpecialSkillName()
		+setSpecialSkillCD()
	    +action()
    }

    class Enemy_Type {
	    -playerControl : Boolean
	    +action()
    }

    class HP_Attribute {
	    -hp : Int
	    -curHP : Int
	    +getHP()
	    +setHP()
	    +changeHP()
    }

    class Attack_Attribute {
	    -attack : Int
	    +getAttack()
	    +setAttack()
	    +changeAttack()
    }

    class Defence_Attribute {
	    -defence : Int
	    +getDefence()
	    +setDefence()
	    +changeDefence()
    }

    class Speed_Attribute {
	    -speed : Int
	    +getSpeed()
	    +setSpeed()
	    +changeSpeed()
    }

	class isAlive {
		-aliveStatus : Boolean
		+getAliveStatus()
		+setAliveStatus()
	}

    class Warrior {
	    -hp : HP_Attribute
	    -attack : Attack_Attribute
	    -defence : Defence_Attribute
	    -speed : Speed_Attribute
	    -startingNumOfItems : Int
	    -specialSkillName : String
		-specialSkillCD : Int
	    +specialSkill(Enemy_type)
	    +action()
    }

    class Wizard {
	    -hp : HP_Attribute
	    -attack : Attack_Attribute
	    -defence : Defence_Attribute
	    -speed : Speed_Attribute
	    -startingNumOfItems : Int
	    -specialSkillName : String
		-specialSkillCD : Int
	    +specialSkill(Enemy_type)
	    +action()
    }

    class Goblin {
	    -hp : HP_Attribute
	    -attack : Attack_Attribute
	    -defence : Defence_Attribute
	    -speed : Speed_Attribute
	    +action()
    }

    class Wolf {
	    -hp : HP_Attribute
	    -attack : Attack_Attribute
	    -defence : Defence_Attribute
	    -speed : Speed_Attribute
	    +action()
    }

    class specialStatus {
	    -statusName : String
	    -statusDuration : Int
	    -curStatusDuration : Int
	    -effectedEntity : Entities
	    -priority : Int
		-hpModifier : HP_Modifier
		-attackModifier : Attack_Modifier
		-defenceModifier : Defence_Modifier
		-speedModifier : Speed_Modifier
		-incomingDamageModifier : Incoming_Dmg_Modifier
		-outcomingDamageModifier : Outgoing_Dmg_Modifier
	    +onHit()
		+onStartTurn()
		+onAllStartTurn()
		+onStartRound()
		+onEndTurn()
		+onAllEndTurn()
		+onEndRound()
		+onDeath()
		+onExpire()
		+onInfliction()
	    +getStatusDuration()
	    +getCurStatusDuration()
	    +changeCurStatusDuration()
		+displayMessage()
    }

    class Arcane_Blast {
	    -statusName : String
	    -statusDuration : Int
	    -curStatusDuration : Int
	    -effectedEntity : Entities
	    -priority : Int
		+onInfliction()
	    +getStatusDuration()
	    +getCurStatusDuration()
	    +changeCurStatusDuration()
    }

    class Stun {
	    -statusName : String
